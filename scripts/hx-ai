#!/bin/bash
# hx-ai: 선택 내용 + 파일경로를 클립보드에 복사
# 사용: :pipe-to hx-ai %{buffer_name} %{cursor_line}

FILEPATH="${1:-unknown}"
CURSOR_LINE="${2:-0}"
SELECTION=$(cat)

CONTENT=$(printf "path: %s (line %s)\n%s\n" "$FILEPATH" "$CURSOR_LINE" "$SELECTION")

if [[ "$(uname)" == "Darwin" ]]; then
  printf '%s' "$CONTENT" | pbcopy
else
  printf '%s' "$CONTENT" | wl-copy >/dev/null 2>&1 &
  disown
fi
